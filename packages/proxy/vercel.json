{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/archive/:owner/:repo/:sha",
      "destination": "/api/archive"
    }
  ],
  "headers": [
    {
      "source": "/api/archive/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
