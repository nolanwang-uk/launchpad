{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://launchpad.dev/schemas/registry-entry.json",
  "title": "Launchpad registry entry",
  "description": "Schema for one entry in registry.json. Every field is required in v1.",
  "type": "object",
  "required": [
    "schema_version",
    "name",
    "description",
    "author",
    "license",
    "repo",
    "sha",
    "tier",
    "targets",
    "capabilities",
    "tags",
    "added_at"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{0,63}$",
      "description": "Short name users type: `skillz run <name>`."
    },
    "description": { "type": "string", "minLength": 1, "maxLength": 280 },
    "author": { "type": "string", "minLength": 1 },
    "license": {
      "type": "string",
      "description": "SPDX identifier, e.g. MIT, Apache-2.0, BSD-3-Clause."
    },
    "repo": {
      "type": "string",
      "pattern": "^[^/]+/[^/]+$",
      "description": "GitHub owner/name pair, e.g. 'launchpad-skills/awesome-refactor'."
    },
    "sha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$",
      "description": "Full 40-char lowercase commit SHA. Tags and branches are rejected at PR time."
    },
    "tier": {
      "type": "string",
      "enum": ["Reviewed", "Community"]
    },
    "targets": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["claude-code"] }
    },
    "capabilities": {
      "type": "object",
      "additionalProperties": false,
      "required": ["network", "filesystem", "shell"],
      "properties": {
        "network": { "type": "boolean" },
        "filesystem": { "type": "boolean" },
        "shell": { "type": "boolean" }
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string", "pattern": "^[a-z0-9-]{1,32}$" },
      "maxItems": 8
    },
    "added_at": {
      "type": "string",
      "format": "date-time"
    },
    "deprecated": {
      "type": "boolean",
      "default": false
    }
  }
}
